# crawl4ai Docker container — environment variables
# Copy this file to .crawl4ai.env and fill in your values.
# .crawl4ai.env is git-ignored — never commit it.

# OpenRouter API key (or any OpenAI-compatible key)
# Get yours at: https://openrouter.ai/keys
OPENAI_API_KEY=your-openrouter-api-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Default model (use any OpenRouter model string)
LLM_PROVIDER=openai/gpt-4o
LLM_TEMPERATURE=0.7
